# Skill #1 — Ingestion Torrent
INGESTION_PORT=8001
TORRENT_CACHE_DIR=/tmp/torrent-cache
MAX_CONCURRENT_SESSIONS=3
MAX_BUFFER_MB=64
PEER_TIMEOUT_SECONDS=120
DOWNLOAD_RATE_LIMIT_KB=0

# Skill #2 — Storage HLS
STORAGE_HLS_PORT=8002
S3_ENDPOINT=http://minio:9000
S3_BUCKET=streaming-hls
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
INGESTION_BASE_URL=http://ingestion-torrent:8001
PUBLIC_API_BASE=http://localhost/api/hls
S3_PUBLIC_BASE_URL=
JOBS_DB_PATH=/data/hls-jobs.db
FFMPEG_THREADS=2
MAX_CONCURRENT_JOBS=2
HLS_SEGMENT_DURATION=6
HLS_WORK_DIR=/tmp/hls-jobs

# Cloudflare R2 (producción)
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_BASE_URL=https://cdn.tudominio.com

# Skill #3 — Live Sports
LIVE_SPORTS_PORT=8003
PUBLIC_API_BASE_LIVE=http://localhost/api/live
PROXY_TIMEOUT_SECONDS=30
BLOCK_PRIVATE_IPS=true
VPN_REQUIRED=false
VPN_HEALTH_URL=http://127.0.0.1:9999/v1/status

# WireGuard (overlay VPN — docker-compose.vpn.yml)
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_ENDPOINT_IP=
WIREGUARD_ENDPOINT_PORT=51820

# Skill #6 — Catalog Metadata
CATALOG_PORT=8004
DATABASE_PATH=/data/catalog.db
INDEXER_PROVIDER=prowlarr
INDEXER_URL=http://prowlarr:9696
INDEXER_API_KEY=
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=
TMDB_API_KEY=
TMDB_LANGUAGE=es-ES
INGEST_MODE=auto
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin
PUBLIC_HLS_BASE=/api/hls
BATCH_CONCURRENCY=2
EPISODE_RESOLVE_LIMIT=42
EPISODE_PLAY_CONCURRENCY=1

# Biblioteca + torrent híbrido
MEDIA_SOURCE_MODE=hybrid
MEDIA_HOST_PATH=/Users/you/Downloads
MEDIA_ROOT=/downloads
QBITTORRENT_DOWNLOAD_PATH=/downloads
TORRENT_MIN_SEEDERS=5
TORRENT_PREFER_HEVC=false
AUTO_ACQUIRE_ON_PLAY=true

# Nginx
NGINX_PORT=80
